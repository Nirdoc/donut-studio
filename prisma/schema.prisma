generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

enum Category {
  classic
  fruity
  premium
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  verified     Boolean  @default(false)
  role         Role     @default(USER)
  createdAt    DateTime @default(now())

  tokens       VerificationToken[]
  resetTokens  PasswordResetToken[]
  comenzi      Comanda[]
  facturi      Factura[]
  addresses    Address[]
}

model Address {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  label      String
  addrType   String   @default("billing")
  judet      String
  city       String
  street     String
  number     String
  type       String   @default("casa")
  bloc       String?
  scara      String?
  etaj       String?
  apartament String?
  createdAt  DateTime @default(now())
}

model Gogoasa {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  price       Float
  image       String
  description String
  ingredients String[]
  allergens   String[]
  calories    Int
  category    Category
  available   Boolean  @default(true)

  kcalServing    Float
  fatServing     Float
  carbsServing   Float
  proteinServing Float

  kcal100g    Float
  fat100g     Float
  carbs100g   Float
  protein100g Float

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Comanda {
  id           String      @id @default(cuid())
  orderNumber  String      @unique

  userId       String?
  user         User?       @relation(fields: [userId], references: [id])

  deliveryDate String
  deliveryTime String

  firstName    String
  lastName     String
  email        String
  phone        String
  cui          String?

  judet        String
  city         String
  street       String
  number       String
  dwellingType String
  bloc         String?
  scara        String?
  etaj         String?
  apartament   String?

  hasDiffDelivery Boolean @default(false)
  delJudet     String?
  delCity      String?
  delStreet    String?
  delNumber    String?
  delType      String?
  delBloc      String?
  delScara     String?
  delEtaj      String?
  delApartament String?

  paymentMethod String
  deliveryFee   Float
  subtotal      Float
  total         Float

  items        Json

  status       String   @default("PENDING")

  factura      Factura?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Factura {
  id            String   @id @default(cuid())
  facturaNumber String   @unique

  comandaId     String   @unique
  comanda       Comanda  @relation(fields: [comandaId], references: [id])

  userId        String?
  user          User?    @relation(fields: [userId], references: [id])

  firstName     String
  lastName      String
  email         String
  phone         String
  cui           String?
  judet         String
  city          String
  street        String
  number        String
  dwellingType  String
  bloc          String?

  subtotal      Float
  deliveryFee   Float
  total         Float

  items         Json

  emailed       Boolean  @default(false)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model VerificationToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
}
